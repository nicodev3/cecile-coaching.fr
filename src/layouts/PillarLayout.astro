---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TunnelCtaLink from '../components/TunnelCtaLink.astro';

type StructuredData = Record<string, unknown>;

interface FaqItem {
	q: string;
	a: string;
}

interface Props {
	title: string;
	description: string;
	path: string;
	breadcrumbLabel: string;
	tunnelCampaign: string;
	faqs: FaqItem[];
}

const { title, description, path, breadcrumbLabel, tunnelCampaign, faqs } = Astro.props;

const crumbs = [
	{ name: 'Accueil', href: '/' },
	{ name: breadcrumbLabel, href: path },
];

const faqStructuredData: StructuredData = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: {
			'@type': 'Answer',
			text: f.a,
		},
	})),
};
---

<BaseLayout title={title} description={description} structuredData={faqStructuredData}>
	<Fragment slot="header">
		<Header />
	</Fragment>

	<article class="border-b border-black/5 bg-white/35">
		<div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
			<Breadcrumbs items={crumbs} />

			<div class="pillar-article text-base leading-relaxed text-slate-800">
				<slot />
			</div>

			<style is:global>
				.pillar-article h2 {
					margin-top: 2.5rem;
					margin-bottom: 0.75rem;
					font-size: 1.5rem;
					font-weight: 600;
					line-height: 1.3;
					color: #0f172a;
				}
				.pillar-article h2:first-child {
					margin-top: 0;
				}
				.pillar-article h3 {
					margin-top: 1.75rem;
					margin-bottom: 0.5rem;
					font-size: 1.125rem;
					font-weight: 600;
					color: #0f172a;
				}
				.pillar-article p {
					margin: 0 0 1rem;
				}
				.pillar-article ul {
					margin: 0 0 1rem 1.25rem;
					list-style: disc;
				}
				.pillar-article li {
					margin-bottom: 0.35rem;
				}
				.pillar-article a {
					color: var(--plum);
					text-decoration: underline;
					text-underline-offset: 3px;
				}
				.pillar-article a:hover {
					color: var(--plum-ink);
				}
				.pillar-article strong {
					font-weight: 700;
					color: #0f172a;
				}
			</style>

			<section class="mt-14 border-t border-black/10 pt-12" aria-labelledby="pillar-faq-title">
				<h2 id="pillar-faq-title" class="text-2xl font-semibold text-slate-900">Questions fréquentes</h2>
				<div class="mt-6 space-y-3">
					{
						faqs.map((f) => (
							<details class="group rounded-2xl bg-white/70 px-5 py-4 ring-1 ring-black/5">
								<summary class="cursor-pointer list-none text-base font-semibold text-slate-900 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)">
									<span class="flex items-center justify-between gap-3">
										<span>{f.q}</span>
										<span
											class="grid h-8 w-8 shrink-0 place-items-center rounded-xl bg-(--sage)/70 text-lg leading-none ring-1 ring-black/5"
											aria-hidden="true"
										>
											<span class="transition group-open:rotate-45">+</span>
										</span>
									</span>
								</summary>
								<p class="mt-3 text-base leading-relaxed text-slate-700">{f.a}</p>
							</details>
						))
					}
				</div>
			</section>

			<div
				class="mt-12 rounded-3xl bg-(--plum) px-6 py-10 text-center text-white shadow-sm shadow-black/15 sm:px-10"
			>
				<h2 class="text-xl font-semibold sm:text-2xl">Passer à l’action, à ton rythme</h2>
				<p class="mt-3 text-base text-white/90">
					Découvre l’immersion gratuite (4 jours) et le programme RE-FLOW sur l’espace dédié.
				</p>
				<div class="mt-6">
					<TunnelCtaLink
						campaign={tunnelCampaign}
						class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-base font-semibold text-slate-900 shadow-sm transition hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
					>
						Commencer l’immersion gratuite (4 jours)
					</TunnelCtaLink>
				</div>
			</div>
		</div>
	</article>
</BaseLayout>
