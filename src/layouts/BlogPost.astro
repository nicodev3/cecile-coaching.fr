---
import { Image } from 'astro:assets';
import { Clock } from '@lucide/astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogArticleFooter from '../components/BlogArticleFooter.astro';
import BlogArticleNewsletter from '../components/BlogArticleNewsletter.astro';
import BlogArticleSidebar from '../components/BlogArticleSidebar.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
import { PILLARS_BY_KEY, type PillarKey } from '../data/pillars';
import { tieFrenchQuestionMark } from '../utils/frenchTypography';
import { COACH_NAME } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	postId: string;
	readingTime: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	relatedPillars,
	postId,
	readingTime,
} = Astro.props;

const tunnelCampaign = `blog_${postId.replace(/[^a-z0-9_-]/gi, '_')}`;
const displayTitle = tieFrenchQuestionMark(title);
const seoTitle = `${displayTitle} | Blog RE-FLOW`;
const seoDescription = description;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const siteUrl = Astro.site?.toString() ?? `${Astro.url.origin}/`;
const siteUrlNormalized = siteUrl.endsWith('/') ? siteUrl.slice(0, -1) : siteUrl;

const primaryPillar = relatedPillars?.[0] as PillarKey | undefined;
const pillar = primaryPillar ? PILLARS_BY_KEY[primaryPillar] : undefined;
const breadcrumbLabel = pillar?.shortLabel ?? 'Article';

const allPosts = await getCollection('blog');
const others = allPosts.filter((p) => p.id !== postId);
const byPillar =
	relatedPillars && relatedPillars.length > 0
		? others.filter((p) => p.data.relatedPillars?.some((k) => relatedPillars.includes(k)))
		: others;
const relatedPosts = [...byPillar]
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 2);
if (relatedPosts.length < 2) {
	const taken = new Set(relatedPosts.map((p) => p.id));
	const fill = others
		.filter((p) => !taken.has(p.id))
		.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
		.slice(0, 2 - relatedPosts.length);
	relatedPosts.push(...fill);
}

const blogPostingStructuredData = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: seoTitle,
	description: seoDescription,
	datePublished: pubDate.toISOString(),
	...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': pageUrl,
	},
	author: {
		'@type': 'Person',
		name: COACH_NAME,
		url: `${siteUrlNormalized}/a-propos/`,
	},
	publisher: {
		'@type': 'Organization',
		name: 'RE-FLOW',
		url: siteUrlNormalized,
	},
	inLanguage: 'fr-FR',
	...(heroImage ? { image: [new URL(heroImage.src, Astro.site).toString()] } : {}),
};
---

<html lang="fr">
	<head>
		<BaseHead title={seoTitle} description={seoDescription} structuredData={blogPostingStructuredData} />
		<style>
			.article-prose {
				font-size: 1.125rem;
				line-height: 1.75;
				color: var(--on-surface-variant);
			}
			.article-prose :global(h2) {
				font-family: var(--font-title);
				font-size: 2rem;
				font-weight: 400;
				color: var(--primary);
				margin: 2.5rem 0 1rem;
				line-height: 1.25;
			}
			.article-prose :global(h3) {
				font-family: var(--font-title);
				font-size: 1.25rem;
				font-weight: 600;
				color: var(--on-surface);
				margin: 2rem 0 0.5rem;
				line-height: 1.35;
			}
			.article-prose :global(p) {
				margin: 0 0 1.5rem;
			}
			.article-prose :global(p:first-child) {
				font-family: var(--font-title);
				font-size: 1.5rem;
				line-height: 1.4;
				font-style: italic;
				color: var(--on-surface);
				margin-bottom: 2.5rem;
				padding-left: 1.5rem;
				border-left: 4px solid var(--primary);
			}
			.article-prose :global(a) {
				color: var(--primary);
				text-decoration: underline;
				text-underline-offset: 3px;
				transition: color 0.15s ease;
			}
			.article-prose :global(a:hover) {
				color: var(--primary-container);
			}
			.article-prose :global(ul),
			.article-prose :global(ol) {
				margin: 0 0 1.5rem 1.5rem;
				padding: 0;
			}
			.article-prose :global(ul) {
				list-style: disc;
				padding-left: 1.5rem;
			}
			.article-prose :global(ul li),
			.article-prose :global(ol li) {
				margin-bottom: 0.75rem;
			}
			.article-prose :global(strong) {
				font-weight: 700;
				color: var(--on-surface);
			}
			.article-prose :global(hr) {
				border: none;
				border-top: 1px solid var(--outline-variant);
				margin: 2.5rem 0;
			}
			.article-prose :global(blockquote) {
				position: relative;
				margin: 3rem 0;
				padding: 2rem;
				background: var(--surface-container-low);
				border: 1px solid var(--outline-variant);
				border-radius: 0.75rem;
				overflow: hidden;
				font-style: italic;
				color: var(--primary);
			}
			.article-prose :global(blockquote::before) {
				content: '“';
				position: absolute;
				top: 0.5rem;
				right: 1rem;
				font-family: var(--font-title);
				font-size: 4rem;
				line-height: 1;
				opacity: 0.15;
				color: var(--primary);
			}
			.article-prose :global(blockquote p) {
				margin: 0 0 0.75rem;
				font-family: var(--font-title);
				font-size: 1.5rem;
				line-height: 1.35;
				font-style: italic;
				color: var(--primary);
			}
			.article-prose :global(blockquote p:last-child) {
				margin-bottom: 0;
			}
			.article-prose :global(code) {
				font-size: 0.875em;
				background: color-mix(in srgb, var(--primary-fixed-dim) 40%, transparent);
				padding: 0.15em 0.4em;
				border-radius: 0.3em;
			}
			.article-prose :global(img) {
				max-width: 100%;
				border-radius: 0.75rem;
				margin: 1.5rem auto;
				display: block;
				box-shadow: var(--box-shadow);
			}
		</style>
	</head>

	<body class="min-h-screen bg-(--background) text-(--on-surface) antialiased">
		<Header />
		<main class="mx-auto max-w-(--max-width-container) px-4 pb-24 sm:px-10">
			<Breadcrumbs
				variant="article"
				items={[
					{ name: 'Blog', href: '/blog/' },
					{
						name: breadcrumbLabel,
						href: pillar?.archiveSlug ?? Astro.url.pathname,
					},
				]}
			/>

			<article>
				<header class="mb-16 grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-8">
					<div class="flex flex-col justify-center md:col-span-8">
						{
							pillar && (
								<a
									href={pillar.archiveSlug}
									class="mb-6 inline-flex w-fit rounded-full bg-(--secondary-container) px-3 py-1 text-xs font-medium tracking-wide text-(--on-secondary-container) no-underline transition hover:bg-(--primary-fixed) hover:text-(--primary-container)"
								>
									{pillar.shortLabel}
								</a>
							)
						}
						<h1 class="mb-6 text-4xl leading-tight text-(--primary) sm:text-5xl">{displayTitle}</h1>
						<div class="flex flex-wrap items-center gap-3 text-sm text-(--outline)">
							<span class="inline-flex items-center gap-1.5">
								<Clock class="h-[18px] w-[18px]" aria-hidden="true" />
								{readingTime} min de lecture
							</span>
							<span class="h-1 w-1 rounded-full bg-(--outline)" aria-hidden="true"></span>
							<span>Par {COACH_NAME}</span>
							<span class="h-1 w-1 rounded-full bg-(--outline)" aria-hidden="true"></span>
							<time datetime={pubDate.toISOString()}>
								<FormattedDate date={pubDate} />
							</time>
							{
								updatedDate && (
									<>
										<span class="h-1 w-1 rounded-full bg-(--outline)" aria-hidden="true"></span>
										<span class="italic">
											Mise à jour le <FormattedDate date={updatedDate} />
										</span>
									</>
								)
							}
						</div>
					</div>
					{
						heroImage && (
							<div class="relative aspect-square overflow-hidden rounded-xl shadow-sm md:col-span-4 md:aspect-auto md:min-h-[280px]">
								<Image
									width={640}
									height={640}
									src={heroImage}
									alt={displayTitle}
									class="h-full w-full object-cover"
								/>
							</div>
						)
					}
				</header>

				<section class="grid grid-cols-1 gap-12 md:grid-cols-12">
					<div class="md:col-span-8">
						<div class="article-prose">
							<slot />
						</div>
						<BlogArticleNewsletter tunnelCampaign={tunnelCampaign} />
						<BlogArticleFooter relatedPillars={relatedPillars} />
					</div>
					<div class="md:col-span-4">
						<BlogArticleSidebar relatedPosts={relatedPosts} />
					</div>
				</section>
			</article>
		</main>
		<Footer />
	</body>
</html>
