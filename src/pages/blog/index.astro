---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { PILLARS } from '../../data/pillars';
import { tieFrenchQuestionMark } from '../../utils/frenchTypography';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

/** Nombre impair d'articles : la dernière carte est seule sur sa ligne — on la centre */
const isOrphanLast = (index: number) =>
	index === posts.length - 1 && posts.length % 2 === 1;

const blogIndexTitle = 'Blog RE-FLOW | Conseils APA et reconnexion corporelle';
const blogIndexDescription =
	'Articles RE-FLOW pour mieux vivre avec une maladie chronique : activité physique adaptée, énergie, douleur et reconnexion corporelle.';
---

<BaseLayout title={blogIndexTitle} description={blogIndexDescription}>
	<Fragment slot="header">
		<Header />
	</Fragment>

	<main class="mx-auto max-w-4xl px-4 py-10 sm:py-12">
		<Breadcrumbs
			items={[
				{ name: 'Accueil', href: '/' },
				{ name: 'Blog', href: '/blog/' },
			]}
		/>
		<section>
			<h1 class="mb-6 text-2xl font-semibold leading-tight text-slate-900 sm:mb-8 sm:text-3xl">
				Articles et ressources sur le coaching pour les femmes touchées par une maladie chronique
			</h1>

			<div class="mb-10 flex flex-wrap gap-2 sm:mb-12" aria-label="Explorer le blog par thème">
				{
					PILLARS.map((p) => (
						<a
							href={p.archiveSlug}
							class="inline-flex items-center gap-1.5 rounded-full bg-white/70 px-4 py-1.5 text-sm font-medium text-slate-800 ring-1 ring-black/5 transition hover:bg-white hover:text-(--plum) hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)"
						>
							<span class="h-1.5 w-1.5 rounded-full bg-(--plum)" aria-hidden="true" />
							Articles {p.shortLabel}
						</a>
					))
				}
			</div>

			<ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-7 lg:gap-8">
				{
					posts.map((post, index) => {
						const orphanLast = isOrphanLast(index);
						const cardTitle = tieFrenchQuestionMark(post.data.title);
						return (
							<li
								class:list={[
									'flex min-h-0',
									orphanLast && 'sm:col-span-2 sm:justify-center',
								]}
							>
								<a
									href={`/blog/${post.id}/`}
									class:list={[
										'group flex h-full min-h-0 w-full max-w-xl flex-col overflow-hidden rounded-2xl bg-white/75 text-left no-underline ring-1 ring-black/5 shadow-sm shadow-black/5 transition duration-200',
										'hover:-translate-y-0.5 hover:shadow-md hover:ring-(--plum)/20 motion-reduce:hover:translate-y-0',
										'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--plum) focus-visible:ring-offset-2 focus-visible:ring-offset-(--sage)',
										'sm:mx-0 sm:max-w-none',
										orphanLast && 'sm:max-w-lg',
									]}
								>
									{post.data.heroImage && (
										<div class="relative aspect-square w-full shrink-0 overflow-hidden bg-(--sage)/50">
											<Image
												width={720}
												height={720}
												src={post.data.heroImage}
												alt={cardTitle}
												class="absolute inset-0 h-full w-full object-contain transition duration-300 ease-out group-hover:scale-[1.03] motion-reduce:group-hover:scale-100"
											/>
											<div
												class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/10 to-transparent opacity-0 transition duration-300 group-hover:opacity-100 motion-reduce:group-hover:opacity-0"
												aria-hidden="true"
											/>
										</div>
									)}
									<div class="flex flex-1 flex-col p-5 sm:p-6">
										<h2 class="m-0 text-lg font-semibold leading-snug text-slate-900 transition-colors duration-200 group-hover:text-(--plum) sm:text-xl">
											{cardTitle}
										</h2>
										<p class="mt-2 text-sm text-slate-600 [&_time]:text-inherit">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<span
											class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-(--plum) transition group-hover:gap-2 motion-reduce:transition-none"
											aria-hidden="true"
										>
											Lire l’article
											<span class="translate-y-px">→</span>
										</span>
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>
		</section>
	</main>
</BaseLayout>
