---
import BlogArchive from '../../../components/BlogArchive.astro';

const title = 'Articles APA — Activités physiques adaptées | Blog RE-FLOW';
const description =
	"Tous les articles RE-FLOW sur les activités physiques adaptées (APA) : définition, métier, différences avec un coach sportif et applications pratiques.";
const intro =
	"Articles dédiés à l'APA : ce qu'elle recouvre, comment elle se distingue d'un coaching sportif classique, et comment elle s'applique au quotidien quand la santé est variable.";
---

<BlogArchive
	pillarKey="apa"
	title={title}
	description={description}
	intro={intro}
/>
