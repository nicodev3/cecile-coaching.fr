---
import BlogArchive from '../../../components/BlogArchive.astro';

const title = 'Articles fatigue chronique et mouvement | Blog RE-FLOW';
const description =
	"Articles RE-FLOW sur la fatigue chronique et le mouvement à distance : doser, raccourcir, garder le contact avec son corps les jours difficiles.";
