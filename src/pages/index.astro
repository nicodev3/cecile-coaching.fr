---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutCoach from '../components/AboutCoach.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PillarsHub from '../components/PillarsHub.astro';
import Pricing from '../components/Pricing.astro';
import ProblemSection from '../components/ProblemSection.astro';
import StepsTimeline from '../components/StepsTimeline.astro';
import Testimonials from '../components/Testimonials.astro';
import TrustStrip from '../components/TrustStrip.astro';
import WhatYouGet from '../components/WhatYouGet.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<BaseLayout
	title="Coach APA en ligne pour femmes en maladie chronique — RE-FLOW"
	description={SITE_DESCRIPTION}
>
	<Fragment slot="header">
		<Header />
	</Fragment>

	<div class="relative">
		<div
			class="pointer-events-none absolute inset-x-0 top-0 h-72 bg-linear-to-b from-white/60 to-transparent"
			aria-hidden="true"
		/>

		<Hero />

		<div class="border-y border-black/5 bg-white/35">
			<TrustStrip />
		</div>

		<div class="border-y border-black/5 bg-(--sage)/12">
			<ProblemSection />
		</div>

		<div class="border-y border-black/5 bg-white/35">
			<StepsTimeline />
		</div>

		<div class="border-y border-black/5 bg-(--sage)/12">
			<WhatYouGet />
		</div>

		<div class="border-y border-black/5 bg-white/35">
			<Pricing />
		</div>

		<AboutCoach />
		<Testimonials />

		<div class="border-y border-black/5 bg-(--sage)/12">
			<PillarsHub />
		</div>

		<div class="border-y border-black/5 bg-white/35">
			<FAQ />
		</div>

		<FinalCTA />

		<div class="border-y border-black/5 bg-(--sage)/12">
			<ContactForm />
		</div>
	</div>
</BaseLayout>
