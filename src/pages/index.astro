---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutCoach from '../components/AboutCoach.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PillarsHub from '../components/PillarsHub.astro';
import Pricing from '../components/Pricing.astro';
import ProblemSection from '../components/ProblemSection.astro';
import StepsTimeline from '../components/StepsTimeline.astro';
import Testimonials from '../components/Testimonials.astro';
import TrustStrip from '../components/TrustStrip.astro';
import WhatYouGet from '../components/WhatYouGet.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<BaseLayout
	title="Coach APA en ligne — Activités physiques adaptées pour femmes en maladie chronique | RE-FLOW"
	description={SITE_DESCRIPTION}
>
	<Fragment slot="header">
		<Header />
	</Fragment>

	<Hero />
	<TrustStrip />
	<ProblemSection />
	<StepsTimeline />
	<WhatYouGet />
	<Pricing />
	<AboutCoach />
	<Testimonials />
	<PillarsHub />
	<FAQ />
	<FinalCTA />
	<ContactForm />
</BaseLayout>
