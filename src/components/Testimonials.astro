---
const testimonials = [
	{
		name: 'Martine',
		meta: 'Accompagnement maladie chronique',
		source: 'Avis Google',
		quote:
			"Grâce à sa motivation et son empathie, je BOUGE ! Entrée avec 1 canne, j'ai remusclé mes jambes et marche sans depuis plusieurs mois.",
		initial: 'M',
		avatarClass: 'bg-(--primary-fixed) text-(--on-primary-fixed-variant)',
	},
	{
		name: 'Nadia',
		meta: 'Fatigue chronique',
		source: '',
		quote:
			"Je n'ai plus cette pression de « performer ». J'avance à mon rythme, et ça change tout pour ma confiance personnelle.",
		initial: 'N',
		avatarClass: 'bg-(--primary-container) text-(--on-primary)',
	},
	{
		name: 'Sophie',
		meta: 'Reconnexion corps-esprit',
		source: '',
		quote:
			"Le suivi est précieux : je me sens comprise, et je sais quoi faire même les jours où je suis moins en forme.",
		initial: 'S',
		avatarClass: 'bg-(--secondary) text-(--on-secondary)',
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="temoignages"
	class={`bg-(--surface-container) py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="testimonials-title"
>
	<div class="mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<h2 id="testimonials-title" class="mb-16 text-center text-3xl text-(--primary) sm:text-5xl">
			Elles ont reconnecté avec leur corps
		</h2>

		<div class="grid gap-8 md:grid-cols-3">
			{testimonials.map((t) => (
				<figure class="flex flex-col justify-between rounded-2xl bg-(--surface) p-8 soft-glow">
					<blockquote class="text-(--secondary) italic leading-relaxed">
						"{t.quote}"
					</blockquote>
					<figcaption class="mt-6 flex items-center gap-4">
						<span
							class:list={[
								'flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-base font-bold',
								t.avatarClass,
							]}
							aria-hidden="true"
						>
							{t.initial}
						</span>
						<div>
							<p class="font-bold text-(--primary)">{t.name}</p>
							<p class="text-xs text-(--secondary)">{t.meta}</p>
							{t.source && <p class="text-xs text-(--secondary)">{t.source}</p>}
						</div>
					</figcaption>
				</figure>
			))}
		</div>
	</div>
</section>
