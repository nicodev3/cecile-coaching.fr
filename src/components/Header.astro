---
import { PILLARS } from '../data/pillars';

interface NavLink {
	href: string;
	label: string;
	/** Lien interne vers une page complète (vs. ancre sur la home) */
	type: 'page' | 'anchor';
}

/**
 * Ordre du menu : logique de funnel "froid → chaud".
 * Programme → Méthode → Comprendre ▾ → À propos → Tarif → Blog → FAQ.
 * Le dropdown "Comprendre" est inséré à l'index 2 (après Méthode) côté rendu.
 */
const rawLinks: NavLink[] = [
	{ href: '#programme', label: 'Programme', type: 'anchor' },
	{ href: '#methode', label: 'Méthode', type: 'anchor' },
	{ href: '/a-propos/', label: 'À propos', type: 'page' },
	{ href: '#tarif', label: 'Tarif', type: 'anchor' },
	{ href: '/blog/', label: 'Blog', type: 'page' },
	{ href: '#faq', label: 'FAQ', type: 'anchor' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const isCurrent = (l: NavLink) => {
	if (l.type === 'anchor') return false;
	if (l.href === '/blog/') return currentPath === '/blog' || currentPath === '/blog/';
	return currentPath.startsWith(l.href);
};

const links = rawLinks.map((l) => {
	const href = !isHome && l.type === 'anchor' ? `/${l.href}` : l.href;
	return { ...l, href, isCurrent: isCurrent(l) };
});

const isUnderstandingActive = PILLARS.some((p) => currentPath.startsWith(p.slug));
---

<header class="sticky top-0 z-40 border-b border-black/5 bg-(--sage)/80 backdrop-blur">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-between gap-4">
			<a
				href="/"
				class="group inline-flex items-center gap-2 rounded-xl px-2 py-1 text-base font-semibold tracking-[0.22em] text-slate-900 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)"
				aria-label="Aller à l’accueil"
			>
				<span
					class="grid h-8 w-8 place-items-center rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-sm transition group-hover:bg-white"
					aria-hidden="true"
				>
					<span class="h-2.5 w-2.5 rounded-full bg-(--plum)"></span>
				</span>
				<span>RE-FLOW</span>
			</a>

			<nav class="hidden items-center gap-1 lg:flex" aria-label="Navigation principale">
				{
					links.slice(0, 2).map((l) => (
						<a
							href={l.isCurrent ? undefined : l.href}
							aria-current={l.isCurrent ? 'page' : undefined}
							class:list={[
								'rounded-xl px-3 py-2 text-base font-medium transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)',
								l.isCurrent
									? 'text-(--plum) font-semibold cursor-default pointer-events-none'
									: 'text-slate-800 hover:bg-white/60 hover:text-slate-900',
							]}
						>
							{l.label}
						</a>
					))
				}

				<details class="group relative" data-understanding-nav>
					<summary
						class:list={[
							'list-none cursor-pointer rounded-xl px-3 py-2 text-base font-medium transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)',
							isUnderstandingActive
								? 'text-(--plum) font-semibold'
								: 'text-slate-800 hover:bg-white/60 hover:text-slate-900',
						]}
						aria-haspopup="menu"
					>
						<span class="inline-flex items-center gap-1.5">
							Comprendre
							<svg
								class="h-3.5 w-3.5 transition group-open:rotate-180"
								viewBox="0 0 20 20"
								fill="currentColor"
								aria-hidden="true"
							>
								<path
									fill-rule="evenodd"
									d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06z"
									clip-rule="evenodd"></path>
							</svg>
						</span>
					</summary>
					<div
						class="absolute left-0 mt-2 w-72 overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-black/10"
						role="menu"
					>
						<div class="p-2">
							{
								PILLARS.map((p) => (
									<a
										href={p.slug}
										role="menuitem"
										class:list={[
											'block rounded-xl px-3 py-2.5 text-sm transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)',
											currentPath.startsWith(p.slug)
												? 'bg-(--sage)/40 text-(--plum) font-semibold'
												: 'text-slate-800 hover:bg-(--sage)/40',
										]}
									>
										<span class="font-medium">{p.label}</span>
										<span class="mt-0.5 block text-xs leading-relaxed text-slate-600">
											{p.tagline}
										</span>
									</a>
								))
							}
						</div>
					</div>
				</details>

				{
					links.slice(2).map((l) => (
						<a
							href={l.isCurrent ? undefined : l.href}
							aria-current={l.isCurrent ? 'page' : undefined}
							class:list={[
								'rounded-xl px-3 py-2 text-base font-medium transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)',
								l.isCurrent
									? 'text-(--plum) font-semibold cursor-default pointer-events-none'
									: 'text-slate-800 hover:bg-white/60 hover:text-slate-900',
							]}
						>
							{l.label}
						</a>
					))
				}
			</nav>

			<div class="hidden lg:flex items-center gap-3">
				<a
					href={isHome ? '#programme' : '/#programme'}
					class="inline-flex items-center justify-center rounded-2xl bg-(--plum) px-4 py-2 text-base font-semibold text-white shadow-sm shadow-black/5 transition hover:brightness-105 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)"
				>
					Découvrir
				</a>
			</div>

			<!-- Mobile -->
			<details class="group relative lg:hidden" data-mobile-nav>
				<summary
					class="list-none inline-flex items-center justify-center rounded-2xl bg-white/60 px-3 py-2 text-base font-semibold text-slate-900 ring-1 ring-black/5 shadow-sm transition hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--plum)"
					aria-label="Ouvrir le menu"
				>
					Menu
				</summary>

				<div
					class="absolute right-0 mt-2 w-[min(92vw,22rem)] overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-black/10"
				>
					<nav class="p-2" aria-label="Menu mobile">
						{
							links.slice(0, 2).map((l) => (
								<a
									href={l.isCurrent ? undefined : l.href}
									aria-current={l.isCurrent ? 'page' : undefined}
									class:list={[
										'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)',
										l.isCurrent
											? 'text-(--plum) font-semibold cursor-default pointer-events-none'
											: 'text-slate-800 hover:bg-(--sage)/60',
									]}
								>
									{l.label}
								</a>
							))
						}

						<div class="mt-2 border-t border-black/5 pt-2">
							<p class="px-3 pb-1 text-xs font-semibold tracking-[0.18em] text-slate-600">
								COMPRENDRE
							</p>
							{
								PILLARS.map((p) => (
									<a
										href={p.slug}
										class:list={[
											'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)',
											currentPath.startsWith(p.slug)
												? 'text-(--plum) font-semibold'
												: 'text-slate-800 hover:bg-(--sage)/60',
										]}
									>
										{p.label}
									</a>
								))
							}
						</div>

						<div class="mt-2 border-t border-black/5 pt-2">
							{
								links.slice(2).map((l) => (
									<a
										href={l.isCurrent ? undefined : l.href}
										aria-current={l.isCurrent ? 'page' : undefined}
										class:list={[
											'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)',
											l.isCurrent
												? 'text-(--plum) font-semibold cursor-default pointer-events-none'
												: 'text-slate-800 hover:bg-(--sage)/60',
										]}
									>
										{l.label}
									</a>
								))
							}
						</div>

						<div class="mt-2 border-t border-black/5 pt-2">
							<a
								href={isHome ? '#programme' : '/#programme'}
								class="block rounded-xl bg-(--plum) px-3 py-2 text-center text-base font-semibold text-white shadow-sm shadow-black/5 hover:brightness-105 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--plum)"
							>
								Découvrir
							</a>
						</div>
					</nav>
				</div>
			</details>
		</div>
	</div>
</header>

<script>
	const mobileNav = document.querySelector<HTMLDetailsElement>('details[data-mobile-nav]');
	if (mobileNav) {
		mobileNav.addEventListener('click', (e) => {
			const t = e.target;
			if (!(t instanceof Element)) return;
			const link = t.closest('a[href]');
			if (!link || !mobileNav.contains(link)) return;
			mobileNav.open = false;
		});
	}

	// Ferme le dropdown desktop "Comprendre" au clic ailleurs / sur un lien.
	const understandingNav = document.querySelector<HTMLDetailsElement>('details[data-understanding-nav]');
	if (understandingNav) {
		understandingNav.addEventListener('click', (e) => {
			const t = e.target;
			if (!(t instanceof Element)) return;
			const link = t.closest('a[href]');
			if (!link || !understandingNav.contains(link)) return;
			understandingNav.open = false;
		});
		document.addEventListener('click', (e) => {
			if (!understandingNav.open) return;
			const t = e.target;
			if (t instanceof Node && understandingNav.contains(t)) return;
			understandingNav.open = false;
		});
	}
</script>
