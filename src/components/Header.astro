---
import { PILLARS } from '../data/pillars';

interface NavLink {
	href: string;
	label: string;
	type: 'page' | 'anchor';
}

const rawLinks: NavLink[] = [
	{ href: '#programme', label: 'Programme', type: 'anchor' },
	{ href: '#methode', label: 'Méthode', type: 'anchor' },
	{ href: '/coach-apa-en-ligne/', label: 'Coach APA en ligne', type: 'page' },
	{ href: '/a-propos/', label: 'À propos', type: 'page' },
	{ href: '#tarif', label: 'Tarif', type: 'anchor' },
	{ href: '/blog/', label: 'Blog', type: 'page' },
	{ href: '#faq', label: 'FAQ', type: 'anchor' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const isCurrent = (l: NavLink) => {
	if (l.type === 'anchor') return false;
	if (l.href === '/blog/') return currentPath.startsWith('/blog');
	return currentPath.startsWith(l.href);
};

const links = rawLinks.map((l) => {
	const href = !isHome && l.type === 'anchor' ? `/${l.href}` : l.href;
	return { ...l, href, isCurrent: isCurrent(l) };
});

const isUnderstandingActive = PILLARS.some((p) => currentPath.startsWith(p.slug));
---

<header class="sticky top-0 z-50 bg-(--surface)/90 shadow-sm backdrop-blur-md">
	<div class="mx-auto flex max-w-(--max-width-container) items-center justify-between gap-4 px-4 py-6 sm:px-10">
		<a
			href="/"
			class="text-2xl tracking-tight text-(--primary) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
			aria-label="Aller à l'accueil"
		>
			RE-FLOW
		</a>

		<nav class="hidden items-center gap-8 lg:flex" aria-label="Navigation principale">
			{
				links.slice(0, 2).map((l) => (
					<a
						href={l.isCurrent ? undefined : l.href}
						aria-current={l.isCurrent ? 'page' : undefined}
						class:list={[
							'text-base transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)',
							l.isCurrent
								? 'pointer-events-none font-semibold text-(--primary)'
								: 'text-(--secondary) hover:text-(--primary)',
						]}
					>
						{l.label}
					</a>
				))
			}

			<details class="group relative" data-understanding-nav>
				<summary
					class:list={[
						'list-none cursor-pointer text-base transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)',
						isUnderstandingActive
							? 'font-semibold text-(--primary)'
							: 'text-(--secondary) hover:text-(--primary)',
					]}
					aria-haspopup="menu"
				>
					<span class="inline-flex items-center gap-1.5">
						Comprendre
						<svg
							class="h-3.5 w-3.5 transition group-open:rotate-180"
							viewBox="0 0 20 20"
							fill="currentColor"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06z"
								clip-rule="evenodd"></path>
						</svg>
					</span>
				</summary>
				<div
					class="absolute left-0 mt-2 w-72 overflow-hidden rounded-2xl bg-(--surface-container-lowest) shadow-lg ring-1 ring-(--outline-variant)/40"
					role="menu"
				>
					<div class="p-2">
						{
							PILLARS.map((p) => (
								<a
									href={p.slug}
									role="menuitem"
									class:list={[
										'block rounded-xl px-3 py-2.5 text-sm transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)',
										currentPath.startsWith(p.slug)
											? 'bg-(--primary-fixed-dim)/30 font-semibold text-(--primary)'
											: 'text-(--on-surface) hover:bg-(--surface-container-low)',
									]}
								>
									<span class="font-medium">{p.label}</span>
									<span class="mt-0.5 block text-xs leading-relaxed text-(--secondary)">
										{p.tagline}
									</span>
								</a>
							))
						}
					</div>
				</div>
			</details>

			{
				links.slice(2).map((l) => (
					<a
						href={l.isCurrent ? undefined : l.href}
						aria-current={l.isCurrent ? 'page' : undefined}
						class:list={[
							'text-base transition focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)',
							l.isCurrent
								? 'pointer-events-none font-semibold text-(--primary)'
								: 'text-(--secondary) hover:text-(--primary)',
						]}
					>
						{l.label}
					</a>
				))
			}
		</nav>

		<div class="hidden items-center gap-3 lg:flex">
			<a
				href={isHome ? '#contact' : '/#contact'}
				class="inline-flex items-center justify-center rounded-full bg-(--primary) px-6 py-2.5 text-base text-(--on-primary) transition hover:bg-(--primary-container) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
			>
				Commencer
			</a>
		</div>

		<details class="group relative lg:hidden" data-mobile-nav>
			<summary
				class="list-none inline-flex items-center justify-center rounded-full border border-(--outline-variant) bg-(--surface-container-lowest) px-4 py-2 text-base font-medium text-(--primary) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
				aria-label="Ouvrir le menu"
			>
				Menu
			</summary>

			<div
				class="absolute right-0 mt-2 w-[min(92vw,22rem)] overflow-hidden rounded-2xl bg-(--surface-container-lowest) shadow-lg ring-1 ring-(--outline-variant)/40"
			>
				<nav class="p-2" aria-label="Menu mobile">
					{
						links.slice(0, 2).map((l) => (
							<a
								href={l.isCurrent ? undefined : l.href}
								aria-current={l.isCurrent ? 'page' : undefined}
								class:list={[
									'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)',
									l.isCurrent
										? 'pointer-events-none font-semibold text-(--primary)'
										: 'text-(--on-surface) hover:bg-(--surface-container-low)',
								]}
							>
								{l.label}
							</a>
						))
					}

					<div class="mt-2 border-t border-(--outline-variant)/40 pt-2">
						<p class="px-3 pb-1 text-xs font-semibold tracking-[0.18em] text-(--secondary)">
							COMPRENDRE
						</p>
						{
							PILLARS.map((p) => (
								<a
									href={p.slug}
									class:list={[
										'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)',
										currentPath.startsWith(p.slug)
											? 'font-semibold text-(--primary)'
											: 'text-(--on-surface) hover:bg-(--surface-container-low)',
									]}
								>
									{p.label}
								</a>
							))
						}
					</div>

					<div class="mt-2 border-t border-(--outline-variant)/40 pt-2">
						{
							links.slice(2).map((l) => (
								<a
									href={l.isCurrent ? undefined : l.href}
									aria-current={l.isCurrent ? 'page' : undefined}
									class:list={[
										'block rounded-xl px-3 py-2 text-base font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)',
										l.isCurrent
											? 'pointer-events-none font-semibold text-(--primary)'
											: 'text-(--on-surface) hover:bg-(--surface-container-low)',
									]}
								>
									{l.label}
								</a>
							))
						}
					</div>

					<div class="mt-2 border-t border-(--outline-variant)/40 pt-2">
						<a
							href={isHome ? '#contact' : '/#contact'}
							class="block rounded-full bg-(--primary) px-3 py-2 text-center text-base font-medium text-(--on-primary) hover:bg-(--primary-container) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)"
						>
							Commencer
						</a>
					</div>
				</nav>
			</div>
		</details>
	</div>
</header>

<script>
	const mobileNav = document.querySelector<HTMLDetailsElement>('details[data-mobile-nav]');
	if (mobileNav) {
		mobileNav.addEventListener('click', (e) => {
			const t = e.target;
			if (!(t instanceof Element)) return;
			const link = t.closest('a[href]');
			if (!link || !mobileNav.contains(link)) return;
			mobileNav.open = false;
		});
	}

	const understandingNav = document.querySelector<HTMLDetailsElement>('details[data-understanding-nav]');
	if (understandingNav) {
		understandingNav.addEventListener('click', (e) => {
			const t = e.target;
			if (!(t instanceof Element)) return;
			const link = t.closest('a[href]');
			if (!link || !understandingNav.contains(link)) return;
			understandingNav.open = false;
		});
		document.addEventListener('click', (e) => {
			if (!understandingNav.open) return;
			const t = e.target;
			if (t instanceof Node && understandingNav.contains(t)) return;
			understandingNav.open = false;
		});
	}
</script>
