---
import { Check } from '@lucide/astro';

const columns = [
	{
		title: 'Ressources fournies',
		items: [
			'Plateforme avec 3 vidéos par semaine',
			'Journal de suivi du niveau de forme et des progrès',
			'Une séance zoom collective tous les 15 jours à suivre en live ou en Replay',
			'Un kit « mauvais jour » de séances express de 5-10 minutes',
		],
	},
	{
		title: 'Rendez-vous de coaching',
		items: [
			'1 bilan forme personnalisé au début et à la fin du programme',
			'Suivi individuel hebdomadaire en visio',
			'Joignable sur WhatsApp : réponse sous 24h',
		],
	},
	{
		title: 'Bonus',
		items: [
			'1 audio de relaxation et 1 audio de respiration',
			'Playlist Spotify de relaxation',
			'Guide PDF « Ma routine bien-être » remis à la fin du programme',
		],
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="tarif"
	class={`bg-(--surface-bright) py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="pricing-title"
>
	<div class="mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<div class="mb-16 text-center">
			<h2 id="pricing-title" class="text-3xl text-(--primary) sm:text-5xl">Programme & modalités</h2>
			<p class="mt-4 text-(--secondary)">
				Un investissement pour retrouver de la stabilité, du tonus, et une relation plus douce avec ton corps.
			</p>
		</div>

		<div class="grid gap-8 md:grid-cols-3">
			{columns.map((col) => (
				<div class="bento-card rounded-2xl bg-(--surface-container-lowest) p-8 soft-glow">
					<h3 class="mb-6 text-2xl text-(--primary)">{col.title}</h3>
					<ul class="space-y-4 text-(--secondary)">
						{col.items.map((item) => (
							<li class="flex gap-3">
								<Check class="mt-0.5 h-4 w-4 shrink-0 text-(--primary)" aria-hidden="true" stroke-width={2} />
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<p class="mt-12 text-center text-lg text-(--primary) italic">
			Durée du programme : 4 mois (16 semaines)
		</p>
		<p class="mt-4 text-center text-(--secondary)">
			Pour connaître le tarif et les modalités de paiement,
			<a class="font-semibold text-(--primary) underline-offset-4 hover:underline" href="#contact">
				écris-moi via le formulaire de contact
			</a>.
		</p>

		<p class="mt-6 text-center text-(--secondary)">
			Questions avant de te décider ?
			<a class="font-semibold text-(--primary) underline-offset-4 hover:underline" href="#faq">Voir la FAQ</a>.
		</p>
	</div>
</section>
