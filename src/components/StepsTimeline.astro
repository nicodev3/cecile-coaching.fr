---
const steps = [
	{
		title: 'Reconnexion & sécurité',
		desc: 'Remettre le corps en mouvement en douceur, installer des pratiques sécuritaires.',
		badgeClass: 'bg-(--primary) text-(--on-primary)',
	},
	{
		title: 'Force & progressivité',
		desc: 'Construire force, stabilité, équilibre et endurance en respectant la fatigue.',
		badgeClass: 'bg-(--primary-fixed-dim) text-(--on-primary-fixed-variant)',
	},
	{
		title: 'Vitalité & énergie',
		desc: "Retrouver plus d'élan et d'endurance, tout en restant à l'écoute de son corps.",
		badgeClass: 'bg-(--primary-container) text-(--on-primary)',
	},
	{
		title: 'Confiance & autonomie',
		desc: 'Stabiliser les progrès et installer une routine durable et joyeuse.',
		badgeClass: 'bg-(--secondary) text-(--on-secondary)',
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="programme"
	class={`bg-(--surface-bright) py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="steps-title"
>
	<div class="mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<div class="mb-20 text-center">
			<h2 id="steps-title" class="text-3xl text-(--primary) sm:text-5xl">
				Les 4 étapes de transformation
			</h2>
			<p class="mt-4 text-(--secondary)">Une progression claire, douce et rassurante.</p>
		</div>

		<ol class="relative mx-auto max-w-3xl space-y-16">
			<div
				class="absolute top-0 bottom-0 left-6 hidden w-px bg-(--outline-variant)/50 md:left-1/2 md:block"
				aria-hidden="true"
			/>
			{
				steps.map((s, idx) => (
					<li
						class:list={[
							'relative flex flex-col items-center gap-8 md:flex-row',
							idx % 2 === 1 && 'md:flex-row-reverse',
						]}
					>
						<div
							class:list={[
								'flex-1',
								idx % 2 === 0 ? 'text-left md:text-right' : 'text-left',
							]}
						>
							<h3 class="text-2xl text-(--primary)">{s.title}</h3>
							<p class="mt-2 text-(--secondary)">{s.desc}</p>
						</div>
						<div
							class:list={[
								'z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-base font-bold',
								s.badgeClass,
							]}
							aria-hidden="true"
						>
							{idx + 1}
						</div>
						<div class="hidden flex-1 md:block" aria-hidden="true" />
					</li>
				))
			}
		</ol>
	</div>
</section>
