---
import { PILLARS } from '../data/pillars';

const today = new Date();
const instagramUrl = 'https://www.instagram.com/cecile.c.oaching/';

const programLinks = [
	{ href: '/#programme', label: 'Méthode' },
	{ href: '/#tarif', label: 'Tarif & modalités' },
	{ href: '/#temoignages', label: 'Témoignages' },
	{ href: '/#faq', label: 'FAQ' },
];

const understandingLinks = PILLARS.map((p) => ({
	href: p.slug,
	label: p.label,
}));

const resourceLinks = [
	{ href: '/blog/', label: 'Blog' },
	{ href: '/mentions-legales/', label: 'Mentions légales' },
	{ href: '/politique-de-confidentialite/', label: 'Confidentialité' },
];
---

<footer class="mt-20 bg-(--surface-container) px-4 py-12 sm:px-10">
	<div class="mx-auto max-w-(--max-width-container)">
		<div class="grid gap-12 md:grid-cols-4">
			<div class="space-y-6">
				<a href="/" class="text-2xl text-(--primary)">RE-FLOW</a>
				<p class="text-(--secondary)">
					Programme de reconnexion corporelle pour les femmes touchées par une maladie chronique.
					Vitalité sans violence.
				</p>
			</div>

			<nav aria-labelledby="footer-program-title">
				<h4 id="footer-program-title" class="mb-6 font-bold text-(--primary)">PROGRAMME</h4>
				<ul class="space-y-3 text-(--on-surface-variant)">
					{
						programLinks.map((l) => (
							<li>
								<a href={l.href} class="transition hover:text-(--primary)">
									{l.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav aria-labelledby="footer-understanding-title">
				<h4 id="footer-understanding-title" class="mb-6 font-bold text-(--primary)">COMPRENDRE</h4>
				<ul class="space-y-3 text-(--on-surface-variant)">
					{
						understandingLinks.map((l) => (
							<li>
								<a href={l.href} class="transition hover:text-(--primary)">
									{l.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav aria-labelledby="footer-resources-title">
				<h4 id="footer-resources-title" class="mb-6 font-bold text-(--primary)">RESSOURCES</h4>
				<ul class="space-y-3 text-(--on-surface-variant)">
					{
						resourceLinks.map((l) => (
							<li>
								<a href={l.href} class="transition hover:text-(--primary)">
									{l.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>

		<div
			class="mt-20 flex flex-col items-center justify-between gap-4 border-t border-(--secondary)/20 pt-8 md:flex-row"
		>
			<p class="text-xs text-(--on-surface-variant)">
				© {today.getFullYear()} RE-FLOW. Tous droits réservés.
			</p>
			<div class="flex gap-6">
				<a
					href={instagramUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="text-(--primary) transition hover:opacity-70"
				>
					Instagram
				</a>
			</div>
		</div>
	</div>
</footer>
