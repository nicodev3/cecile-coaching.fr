---
import { BedDouble, Frown, PersonStanding, TrendingDown } from '@lucide/astro';

const cycle = [
	{
		title: 'Fatigue',
		desc: "L'énergie baisse, on réduit les mouvements.",
		icon: BedDouble,
	},
	{
		title: 'Moins de mouvement',
		desc: "Le corps est moins sollicité, la prudence s'installe.",
		icon: TrendingDown,
	},
	{
		title: 'Perte de tonus',
		desc: "La force et l'endurance diminuent peu à peu.",
		icon: PersonStanding,
	},
	{
		title: 'Découragement',
		desc: 'On doute, et reprendre devient difficile.',
		icon: Frown,
	},
];

const pillars = [
	{
		title: 'Selon ton énergie',
		desc: 'Des versions plus douces quand tu en as besoin.',
	},
	{
		title: 'Progressivement',
		desc: 'Reconstruire la confiance sans brusquer le corps.',
	},
	{
		title: 'Cadre clair',
		desc: 'Savoir quoi faire pour ne pas se mettre en échec.',
	},
	{
		title: 'Le cap',
		desc: 'Refaire une place au mouvement durablement.',
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="methode"
	class={`py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="problem-title"
>
	<div class="mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<div class="mb-16 space-y-4 text-center">
			<h2 id="problem-title" class="text-3xl text-(--primary) sm:text-5xl">
				Sortir de l'engrenage
			</h2>
			<p class="mx-auto max-w-2xl text-lg leading-relaxed text-(--secondary)">
				Quand la fatigue s'installe, bouger moins semble protéger. Mais ensemble, nous pouvons inverser la tendance.
			</p>
		</div>

		<div class="grid gap-6 md:grid-cols-12">
			<div class="flex flex-col justify-between rounded-xl bg-(--surface-container) p-8 md:col-span-5">
				<h3 class="mb-8 text-2xl text-(--primary)">Le cycle de l'inactivité</h3>
				<div class="space-y-6">
					{cycle.map((item) => (
						<div class="flex items-start gap-4 rounded-lg border border-(--outline-variant)/30 bg-(--surface)/50 p-4">
							<item.icon class="mt-0.5 h-5 w-5 shrink-0 text-(--primary-container)" aria-hidden="true" stroke-width={1.5} />
							<div>
								<p class="font-bold text-(--primary)">{item.title}</p>
								<p class="text-sm text-(--secondary)">{item.desc}</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="relative flex flex-col justify-center overflow-hidden rounded-xl bg-(--primary) p-8 text-(--on-primary) sm:p-12 md:col-span-7">
				<div class="relative z-10 space-y-12">
					<h3 class="text-3xl text-(--on-primary) sm:text-5xl">La solution RE-FLOW</h3>
					<div class="grid gap-8 sm:grid-cols-2">
						{pillars.map((pillar) => (
							<div class="space-y-2">
								<h4 class="text-xl text-(--primary-fixed)">{pillar.title}</h4>
								<p class="text-(--on-primary-container)">{pillar.desc}</p>
							</div>
						))}
					</div>
					<a
						href="#programme"
						class="inline-block rounded-full bg-(--surface) px-8 py-4 text-base font-semibold text-(--primary) transition hover:bg-(--primary-fixed)"
					>
						Découvrir la méthode
					</a>
				</div>
				<div
					class="pointer-events-none absolute -right-20 -bottom-20 h-80 w-80 rounded-full bg-(--primary-container)/30 blur-[80px]"
					aria-hidden="true"
				/>
			</div>
		</div>
	</div>
</section>
