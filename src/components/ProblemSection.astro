---
import { Activity, CloudSun, Cog, Compass, ShieldCheck } from '@lucide/astro';

const cycle = [
	{
		title: 'Fatigue',
		desc: 'Quand l’énergie baisse, on réduit naturellement les mouvements.',
	},
	{
		title: 'Moins de mouvement',
		desc: 'Le corps est moins sollicité, et le quotidien devient plus prudent.',
	},
	{
		title: 'Perte de tonus',
		desc: 'La force, la stabilité et l’endurance diminuent peu à peu.',
	},
	{
		title: 'Découragement',
		desc: 'On doute davantage, et reprendre devient encore plus difficile.',
	},
];

const pillars = [
	{
		title: 'Selon ton énergie',
		desc: 'Les séances s’adaptent au jour que tu traverses, avec des versions plus douces quand tu en as besoin.',
		icon: CloudSun,
	},
	{
		title: 'Progressivement',
		desc: 'On reconstruit le tonus, la stabilité et la confiance sans brusquer ton corps.',
		icon: Activity,
	},
	{
		title: 'Avec un cadre clair',
		desc: 'Tu sais quoi faire, quoi ajuster et comment avancer sans te mettre en échec.',
		icon: ShieldCheck,
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="methode"
	class={`py-14 sm:py-18 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="problem-title"
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-3xl text-center">
			<h2 id="problem-title" class="text-3xl font-semibold text-slate-900">
				Quand l’inactivité s’installe, un engrenage peut se créer
			</h2>

			<p class="mt-4 text-base leading-relaxed text-slate-700">
				Quand on vit avec une fatigue chronique ou un corps plus fragile, bouger moins peut sembler protéger.
				Mais avec le temps, cela peut aussi entretenir un cercle qui épuise encore davantage.
			</p>
		</div>

		<div class="mt-10 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
			{cycle.map((item, index) => (
				<div class="rounded-3xl bg-slate-100 p-5 ring-1 ring-slate-300/50 shadow-sm shadow-slate-900/4">
					<div class="grid h-9 w-9 place-items-center rounded-2xl bg-slate-200/90 ring-1 ring-slate-400/30">
						<Cog
							class={`h-5 w-5 text-slate-600 ${index % 2 === 1 ? 'rotate-12' : '-rotate-12'}`}
							aria-hidden="true"
							stroke-width={1.5}
						/>
					</div>
					<p class="mt-2 text-base font-semibold text-slate-800">{item.title}</p>
					<p class="mt-2 text-sm leading-relaxed text-slate-600 sm:text-base">{item.desc}</p>
				</div>
			))}
		</div>

		<div class="mx-auto mt-10 max-w-3xl text-center">
			<h3 class="text-2xl font-semibold text-slate-900">
				RE-FLOW aide à sortir de cet engrenage, sans brusquer ton corps
			</h3>
			<p class="mt-4 text-base leading-relaxed text-slate-700">
				Ici, il ne s’agit pas de te pousser. Il s’agit de retrouver du mouvement d’une manière compatible avec ton énergie,
				ton quotidien et ton corps.
			</p>
		</div>

		<div class="mt-8 grid gap-4 lg:grid-cols-3">
			{pillars.map((pillar) => (
				<div class="rounded-4xl bg-white p-7 ring-1 ring-(--sage)/30 shadow-sm shadow-(--sage)/10">
					<div class="flex items-center gap-3">
						<div class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-(--sage)/35 ring-1 ring-(--sage)/30">
							<pillar.icon class="h-5 w-5 text-(--plum-ink)" aria-hidden="true" stroke-width={1.7} />
						</div>
						<p class="text-base font-semibold text-slate-900">{pillar.title}</p>
					</div>
					<p class="mt-4 text-base leading-relaxed text-slate-700">{pillar.desc}</p>
				</div>
			))}
		</div>

		<div class="mt-8 overflow-hidden rounded-4xl bg-(--sage)/12 p-6 ring-1 ring-(--sage)/25 sm:p-7">
			<div class="flex gap-3 sm:items-start">
				<div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-white ring-1 ring-(--sage)/25">
					<Compass class="h-5 w-5 text-(--plum-ink)" aria-hidden="true" stroke-width={1.7} />
				</div>
				<div class="min-w-0">
					<p class="text-base font-semibold text-slate-900">Le cap</p>
					<p class="mt-1 text-base leading-relaxed text-slate-700">
						Le but n’est pas d’en faire plus. Le but est de refaire une place au mouvement, durablement.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
