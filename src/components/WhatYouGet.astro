---
import { Check } from '@lucide/astro';

const cards = [
	{
		title: 'Ressources',
		items: [
			'Séances guidées à suivre chez toi.',
			'Routines « bons jours / jours difficiles ».',
			'Supports clairs pour garder le cap.',
		],
	},
	{
		title: 'Coaching',
		items: [
			'Points réguliers pour ajuster au réel.',
			'Conseils personnalisés selon ton énergie.',
			'Un cadre qui te sécurise.',
		],
	},
	{
		title: 'Bonus',
		items: [
			'Respiration & relaxation apaisante.',
			'Mini-séances express de 5-10 min.',
			"Checklist simple d'autonomie.",
		],
	},
];

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	class={`bg-(--surface-container-low) py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="what-title"
>
	<div class="mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<div class="mb-16 text-center">
			<h2 id="what-title" class="text-3xl text-(--primary) sm:text-5xl">
				Concrètement, tu reçois
			</h2>
			<p class="mt-4 text-(--secondary)">Un programme clair, respirable et adapté.</p>
		</div>

		<div class="grid gap-8 md:grid-cols-3">
			{cards.map((c) => (
				<div class="bento-card rounded-2xl bg-(--surface-container-lowest) p-8 soft-glow">
					<h3 class="mb-6 text-2xl text-(--primary)">{c.title}</h3>
					<ul class="space-y-4 text-(--secondary)">
						{c.items.map((it) => (
							<li class="flex gap-3">
								<Check class="mt-0.5 h-4 w-4 shrink-0 text-(--primary)" aria-hidden="true" stroke-width={2} />
								<span>{it}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<p class="mt-12 text-center text-lg text-(--primary) italic">
			Durée : 4 mois — progressif, sans surcharger.
		</p>
	</div>
</section>
