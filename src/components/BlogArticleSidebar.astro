---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { PILLARS_BY_KEY, type PillarKey } from '../data/pillars';
import { tieFrenchQuestionMark } from '../utils/frenchTypography';
import { estimateReadingTime } from '../utils/readingTime';

interface Props {
	relatedPosts: CollectionEntry<'blog'>[];
}

const { relatedPosts } = Astro.props;

function postMeta(post: CollectionEntry<'blog'>) {
	const pillarKey = post.data.relatedPillars?.[0] as PillarKey | undefined;
	const label = pillarKey ? PILLARS_BY_KEY[pillarKey].shortLabel : 'RE-FLOW';
	const minutes = estimateReadingTime(post.body ?? post.data.description);
	return `${label} • ${minutes} min`;
}
---

<aside class="space-y-12" aria-label="Compléments d'article">
	{
		relatedPosts.length > 0 && (
			<div>
				<h2 class="mb-6 border-b border-(--outline-variant) pb-2 text-sm font-semibold tracking-widest text-(--primary) uppercase">
					Articles similaires
				</h2>
				<div class="space-y-8">
					{relatedPosts.map((post) => {
						const cardTitle = tieFrenchQuestionMark(post.data.title);
						return (
							<a
								href={`/blog/${post.id}/`}
								class="group block no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
							>
								<div class="mb-4 aspect-video overflow-hidden rounded-lg bg-(--surface-container)">
									{post.data.heroImage ? (
										<Image
											width={480}
											height={270}
											src={post.data.heroImage}
											alt={cardTitle}
											class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 motion-reduce:group-hover:scale-100"
										/>
									) : (
										<div
											class="flex h-full w-full items-center justify-center bg-(--primary-fixed-dim)/20 text-sm font-medium text-(--primary-container)"
											aria-hidden="true"
										>
											RE-FLOW
										</div>
									)}
								</div>
								<h3 class="text-xl leading-tight text-(--on-surface) transition-colors group-hover:text-(--primary)">
									{cardTitle}
								</h3>
								<p class="mt-2 text-xs font-medium tracking-wide text-(--outline) uppercase">
									{postMeta(post)}
								</p>
							</a>
						);
					})}
				</div>
			</div>
		)
	}

	<div class="rounded-xl border border-(--outline-variant) bg-(--surface-container) p-8">
		<h2 class="mb-4 text-2xl text-(--primary)">Besoin d'un conseil ?</h2>
		<p class="mb-6 text-(--on-surface-variant)">
			Échange gratuit de 15 minutes à distance pour voir si l'accompagnement RE-FLOW correspond à ta situation.
		</p>
		<a
			href="/contact/"
			class="inline-flex w-full items-center justify-center rounded-full border border-(--primary) px-6 py-3 text-sm font-semibold text-(--primary) transition hover:bg-(--primary) hover:text-(--on-primary) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
		>
			Réserver un échange en ligne
		</a>
	</div>
</aside>

