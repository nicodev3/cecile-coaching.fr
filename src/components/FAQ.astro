---
import WhatsAppCtaLink from './WhatsAppCtaLink.astro';

const faqs = [
	{
		q: "C'est quoi l'APA ?",
		a: "C'est une formation reconnue qui permet d'adapter le mouvement à ton état de santé, tes capacités et tes limites. Chez RE-FLOW, ce cadre sécurisant et progressif se vit en ligne.",
	},
	{
		q: 'Est-ce adapté si mon énergie fluctue ?',
		a: "Oui. Le programme s'adapte à tes variations d'énergie, avec des options plus douces et des durées modulables selon ton ressenti quotidien.",
	},
	{
		q: 'Faut-il déjà être sportive ?',
		a: "Non. L'approche est progressive, sans objectif de performance. On part de ton point de départ actuel, avec douceur.",
	},
	{
		q: 'Combien de temps prévoir ?',
		a: 'Le programme en ligne prévoit environ 3 séances de 30 minutes par semaine, ajustables selon ton énergie, avec un suivi en visio.',
	},
	{
		q: 'Et si je ressens des douleurs ?',
		a: "Je t'aide à ajuster (amplitudes, respiration, intensité). Si une douleur apparaît, on privilégie l'adaptation.",
	},
	{
		q: 'Comment se passe le paiement ?',
		a: 'Un paiement en plusieurs fois est possible (2x ou 3x). Je te précise le tarif et les modalités lors de notre échange.',
	},
	{
		q: 'Est-ce adapté pour toutes les maladies chroniques ?',
		a: "Oui, l'accompagnement peut se faire à distance pour de nombreuses situations. On ne soigne pas la maladie, mais on travaille le déconditionnement physique qui en découle.",
	},
	{
		q: "Qui peut encadrer une activité physique adaptée ?",
		a: "En France, l'APA est encadrée par des enseignant·es en Activité Physique Adaptée, titulaires d'une licence ou d'un master STAPS mention APA-S (Activité Physique Adaptée et Santé). Ce n'est ni un coach sportif généraliste, ni un kinésithérapeute : c'est une formation universitaire spécifique à l'accompagnement des personnes fragilisées par la maladie ou le handicap.",
	},
	{
		q: "L'activité physique adaptée, c'est pour qui ?",
		a: "Pour toute personne dont l'état de santé nécessite une approche du mouvement personnalisée : maladie chronique, fatigue persistante, déconditionnement physique, post-traitement, handicap moteur ou sensoriel. L'APA n'est pas réservée aux sportifs — elle s'adresse justement à celles et ceux qui ne peuvent pas (ou plus) pratiquer comme « tout le monde ».",
	},
];

const faqStructuredData = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: {
			'@type': 'Answer',
			text: f.a,
		},
	})),
};

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="faq"
	class={`py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="faq-title"
>
	<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
		<h2 id="faq-title" class="mb-12 text-center text-3xl text-(--primary) sm:text-5xl">
			Quelques réponses rapides
		</h2>

		<div class="space-y-4">
			{faqs.map((f) => (
				<details class="group overflow-hidden rounded-xl bg-(--surface-container-low) transition-all">
					<summary class="flex cursor-pointer list-none items-center justify-between p-6 outline-none focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)">
						<h3 class="pr-4 text-xl text-(--primary)">{f.q}</h3>
						<span
							class="text-2xl text-(--primary) transition group-open:rotate-45"
							aria-hidden="true"
						>
							+
						</span>
					</summary>
					<p class="px-6 pt-0 pb-6 text-(--secondary)">{f.a}</p>
				</details>
			))}
		</div>

		<div class="mt-12 rounded-2xl bg-(--whatsapp-surface) px-6 py-8 text-center ring-1 ring-(--whatsapp)/15">
			<p class="text-lg text-(--secondary)">Tu n'as pas trouvé ta réponse ?</p>
			<p class="mt-2 text-(--on-surface-variant)">Écris-moi sur WhatsApp, je te réponds sous 24 h.</p>
			<WhatsAppCtaLink
				campaign="faq"
				showIcon={true}
				class="whatsapp-btn mt-6 rounded-full px-8 py-3 text-base font-semibold"
			>
				Poser ma question sur WhatsApp
			</WhatsAppCtaLink>
		</div>
	</div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)}></script>
