---
import { MessageCircle, Phone } from '@lucide/astro';
import WhatsAppCtaLink from './WhatsAppCtaLink.astro';

const formspreeEndpoint = 'https://formspree.io/f/mnjoqddy';

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="contact"
	class={`bg-(--surface) py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="contact-title"
>
	<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
		<div class="text-center">
			<h2 id="contact-title" class="text-3xl text-(--primary) sm:text-5xl">Me contacter</h2>
			<p class="mt-2 text-(--secondary)">Posez vos questions ou démarrez votre accompagnement en ligne.</p>
		</div>

		<div class="mt-8 grid gap-3 sm:grid-cols-[1.15fr_0.85fr]">
			<WhatsAppCtaLink
				campaign="contact"
				class="group flex items-start gap-3 rounded-2xl bg-(--whatsapp-surface) p-4 text-left ring-1 ring-(--whatsapp)/15 transition hover:bg-white hover:ring-(--whatsapp)/30 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--whatsapp)"
				aria-label="Poser une question rapide sur WhatsApp"
			>
				<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white text-(--whatsapp)">
					<MessageCircle class="h-5 w-5" aria-hidden="true" stroke-width={2} />
				</span>
				<span>
					<span class="block text-base font-semibold text-(--on-surface)">Question rapide sur WhatsApp</span>
					<span class="mt-1 block text-sm leading-relaxed text-(--on-surface-variant)">
						Idéal pour vérifier si l'accompagnement peut convenir à ta situation.
					</span>
				</span>
			</WhatsAppCtaLink>
			<div class="flex items-start gap-3 rounded-2xl bg-(--surface-container-low) p-4">
				<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white text-(--secondary)">
					<Phone class="h-5 w-5" aria-hidden="true" stroke-width={2} />
				</span>
				<span>
					<span class="block text-sm text-(--secondary)">Préférer appeler</span>
					<a
						id="phone-link"
						href="#"
						class="mt-1 block text-base font-semibold text-(--primary) hover:underline"
						aria-label="Téléphone"
					>
						<span id="phone-display">Chargement...</span>
					</a>
				</span>
			</div>
		</div>

		<form
			name="contact"
			method="POST"
			action={formspreeEndpoint}
			class="mt-8 space-y-6"
		>
			<div class="sr-only" aria-hidden="true">
				<label for="contact-gotcha">Ne pas remplir</label>
				<input type="text" id="contact-gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
			</div>

			<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
				<div class="space-y-2">
					<label for="name" class="text-sm font-semibold text-(--primary)">
						Nom <span class="text-(--secondary)">*</span>
					</label>
					<input
						type="text"
						id="name"
						name="name"
						required
						class="w-full rounded-xl border-none bg-(--surface-container-low) p-4 text-(--on-surface) transition focus:ring-2 focus:ring-(--primary-fixed) focus:outline-none"
						placeholder="Ton nom"
					/>
				</div>
				<div class="space-y-2">
					<label for="email" class="text-sm font-semibold text-(--primary)">
						Email <span class="text-(--secondary)">*</span>
					</label>
					<input
						type="email"
						id="email"
						name="email"
						required
						class="w-full rounded-xl border-none bg-(--surface-container-low) p-4 text-(--on-surface) transition focus:ring-2 focus:ring-(--primary-fixed) focus:outline-none"
						placeholder="ton@email.com"
					/>
				</div>
			</div>

			<div class="space-y-2">
				<label for="phone" class="text-sm font-semibold text-(--primary)">Téléphone</label>
				<input
					type="tel"
					id="phone"
					name="phone"
					class="w-full rounded-xl border-none bg-(--surface-container-low) p-4 text-(--on-surface) transition focus:ring-2 focus:ring-(--primary-fixed) focus:outline-none"
					placeholder="06 12 34 56 78 (optionnel)"
				/>
			</div>

			<div class="space-y-2">
				<label for="message" class="text-sm font-semibold text-(--primary)">
					Message <span class="text-(--secondary)">*</span>
				</label>
				<textarea
					id="message"
					name="message"
					required
					rows="5"
					class="w-full rounded-xl border-none bg-(--surface-container-low) p-4 text-(--on-surface) transition focus:ring-2 focus:ring-(--primary-fixed) focus:outline-none"
					placeholder="Ton message..."
				></textarea>
			</div>

			<div
				id="form-success"
				class="hidden rounded-xl bg-(--primary-fixed)/40 p-4 text-(--on-primary-fixed-variant) ring-1 ring-(--primary-fixed-dim)"
			>
				<p class="font-medium">Message envoyé avec succès !</p>
				<p class="mt-1">Je te répondrai dans les meilleurs délais.</p>
			</div>

			<div id="form-error" class="hidden rounded-xl bg-red-50 p-4 text-red-800 ring-1 ring-red-200">
				<p class="font-medium">Une erreur est survenue.</p>
				<p class="mt-1">
					Veuillez réessayer ou m'envoyer un email directement à cecile.c.coach@gmail.com
				</p>
			</div>

			<button
				type="submit"
				class="w-full rounded-full bg-(--primary) py-5 text-base font-bold text-(--on-primary) transition hover:bg-(--primary-container) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
			>
				Demander un échange à distance
			</button>
		</form>
	</div>
</section>

<script is:inline>
	(function () {
		const a = '0' + '6';
		const b = '8' + '6';
		const c = '4' + '1';
		const d = '5' + '7';
		const e = '0' + '1';
		const phoneNumber = a + b + c + d + e;
		const phoneDisplay = phoneNumber.replace(/(\d{2})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5');

		const phoneLink = document.getElementById('phone-link');
		const phoneDisplayEl = document.getElementById('phone-display');

		if (phoneLink && phoneDisplayEl) {
			phoneLink.href = 'tel:+33' + phoneNumber.substring(1);
			phoneDisplayEl.textContent = phoneDisplay;
		}
	})();
</script>

<script define:vars={{ formspreeEndpoint }}>
	const form = document.querySelector('form[name="contact"]');
	const formSuccess = document.getElementById('form-success');
	const formError = document.getElementById('form-error');

	if (form instanceof HTMLFormElement) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			const formData = new FormData(form);
			const submitButton = form.querySelector('button[type="submit"]');
			const originalText = submitButton?.textContent;

			formSuccess?.classList.add('hidden');
			formError?.classList.add('hidden');

			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
				submitButton.textContent = 'Envoi en cours...';
			}

			try {
				const response = await fetch(formspreeEndpoint, {
					method: 'POST',
					headers: { Accept: 'application/json' },
					body: formData,
				});

				if (response.ok) {
					formSuccess?.classList.remove('hidden');
					form.reset();
					formSuccess?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
				} else {
					throw new Error('Erreur lors de l\'envoi');
				}
			} catch (error) {
				formError?.classList.remove('hidden');
				formError?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			} finally {
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
					if (originalText) {
						submitButton.textContent = originalText;
					}
				}
			}
		});
	}
</script>
