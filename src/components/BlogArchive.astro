---
import BlogListing from './BlogListing.astro';
import { PILLARS_BY_KEY, type PillarKey } from '../data/pillars';

interface Props {
	pillarKey: PillarKey;
	title: string;
	description: string;
	intro: string;
}

const { pillarKey, title, description, intro } = Astro.props;
const pillar = PILLARS_BY_KEY[pillarKey];
---

<BlogListing
	activeFilter={pillarKey}
	pageTitle={title}
	pageDescription={description}
	heroTitle={`Articles ${pillar.shortLabel}`}
	heroIntro={intro}
	guideLink={{ href: pillar.slug, label: `Guide complet : ${pillar.label}` }}
/>
