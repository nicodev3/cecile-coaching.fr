---
import WhatsAppCtaLink from './WhatsAppCtaLink.astro';
import WhatsAppIcon from './WhatsAppIcon.astro';
---

<WhatsAppCtaLink
	campaign="floating"
	class="whatsapp-floating-btn fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-(--whatsapp) text-white shadow-lg transition hover:bg-(--whatsapp-hover) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--whatsapp)"
	aria-label="Contacter Cécile sur WhatsApp"
>
	<WhatsAppIcon class="h-7 w-7" />
</WhatsAppCtaLink>
