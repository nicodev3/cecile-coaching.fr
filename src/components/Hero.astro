---
import { Image } from 'astro:assets';
import TunnelCtaLink from './TunnelCtaLink.astro';
import heroImageWebp from '../assets/femme-yoga.webp';

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	class={`relative flex min-h-[90vh] items-center overflow-hidden px-4 py-20 sm:px-10 lg:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="hero-title"
>
	<div
		class="pointer-events-none absolute top-1/2 -right-64 h-[600px] w-[600px] rounded-full bg-(--primary-fixed-dim)/10 blur-[120px]"
		aria-hidden="true"
	/>

	<div class="relative z-10 mx-auto grid w-full max-w-(--max-width-container) grid-cols-1 items-center gap-12 md:grid-cols-2">
		<div class="space-y-8">
			<p class="text-sm font-semibold tracking-[0.2em] text-(--primary-container) uppercase">
				Coach certifiée APA
			</p>
			<h1
				id="hero-title"
				class="text-4xl leading-tight text-(--primary) sm:text-5xl lg:text-[3rem] lg:leading-[1.15]"
			>
				Coach APA pour femmes en maladie chronique : quand le corps redevient un allié
			</h1>
			<p class="max-w-xl text-lg leading-relaxed text-(--secondary)">
				Le programme de reconnexion corporelle pour les femmes touchées par une maladie chronique.
				Mouvement adapté, à ton rythme, sans culture de la performance.
			</p>
			<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
				<a
					href="#programme"
					class="inline-flex items-center justify-center rounded-full bg-(--primary) px-8 py-4 text-base font-medium text-(--on-primary) soft-glow transition hover:bg-(--primary-container)"
				>
					Découvrir le programme
				</a>
				<TunnelCtaLink
					campaign="hero"
					class="inline-flex items-center justify-center rounded-full border border-(--outline-variant) px-8 py-4 text-center text-base font-medium text-(--primary) transition hover:bg-(--surface-container)"
				>
					Immersion gratuite (4 jours)
				</TunnelCtaLink>
			</div>
			<p class="text-sm leading-relaxed text-(--secondary)">
				Nouvelle ici ? Commence par comprendre les
				<a
					href="/activites-physiques-adaptees/"
					class="font-semibold text-(--primary) underline underline-offset-4 transition hover:text-(--primary-container)"
				>
					activités physiques adaptées (APA)
				</a>
				et leur intérêt quand la santé varie.
			</p>
		</div>

		<div class="group relative">
			<div
				class="pointer-events-none absolute -inset-4 rounded-[2rem] bg-(--primary-container)/10 blur-2xl transition group-hover:blur-3xl"
				aria-hidden="true"
			/>
			<Image
				src={heroImageWebp}
				alt="Femme en méditation, assise en tailleur."
				fetchpriority="high"
				loading="eager"
				decoding="async"
				class="relative h-[min(600px,70vh)] w-full rounded-[2rem] object-cover soft-glow"
			/>
		</div>
	</div>
</section>
