---
import coachImage from '../assets/cecile-coach-apa.webp';

const ytVideoId = 'tT4GFMTYE4k';
const ytEmbedQuery =
	'si=JiE3xxtSmPTgzafW&modestbranding=1&rel=0&playsinline=1';
const ytEmbedUrl = `https://www.youtube.com/embed/${ytVideoId}?${ytEmbedQuery}`;
const ytEmbedUrlAutoplay = `${ytEmbedUrl}&autoplay=1`;

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="propos"
	class={`overflow-hidden py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="coach-title"
>
	<div class="mx-auto flex max-w-(--max-width-container) flex-col items-center gap-16 px-4 sm:px-6 md:flex-row lg:px-8">
		<div class="relative w-full md:w-1/2">
			<div
				class="pointer-events-none absolute -inset-4 -z-10 rotate-3 rounded-2xl border-2 border-(--primary-fixed-dim)"
				aria-hidden="true"
			/>
			<img
				src={coachImage.src}
				width={coachImage.width}
				height={coachImage.height}
				alt="Cécile, coach certifiée APA — Activités Physiques Adaptées"
				loading="lazy"
				decoding="async"
				class="w-full rounded-2xl object-cover shadow-xl soft-glow"
			/>
		</div>

		<div class="w-full space-y-6 md:w-1/2">
			<p class="text-sm font-semibold tracking-[0.2em] text-(--primary-container) uppercase">Qui suis-je ?</p>
			<h2 id="coach-title" class="text-3xl text-(--primary) sm:text-5xl">Cécile</h2>
			<p class="text-lg leading-relaxed text-(--secondary)">
				Spécialisée en Activités Physiques Adaptées, je t'accompagne à distance dans ta reconnexion corporelle
				avec une approche douce et progressive, adaptée à ton rythme et à ton niveau d'énergie.
			</p>
			<p class="leading-relaxed text-(--secondary)">
				Mon expérience me permet de construire un programme en ligne qui respecte tes limites et tes besoins
				concrets. Ensemble, nous allons retrouver de la confiance dans ton corps, sans pression ni performance.
			</p>

			<div class="w-full pt-4">
				<div
					id="coach-video-root"
					class="relative aspect-video overflow-hidden rounded-2xl bg-black shadow-lg ring-1 ring-(--outline-variant)/30"
				>
					<iframe
						class="absolute inset-0 hidden h-full w-full border-0 lg:block"
						src={ytEmbedUrl}
						title="Vidéo de présentation — Cécile, coach APA en ligne"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen"
						referrerpolicy="strict-origin-when-cross-origin"
						allowfullscreen
						loading="lazy"
					/>
					<img
						src={`https://i.ytimg.com/vi/${ytVideoId}/hqdefault.jpg`}
						alt="Cécile, coach certifiée APA — Activités Physiques Adaptées"
						class="coach-yt-poster absolute inset-0 z-0 h-full w-full object-cover lg:hidden"
						loading="lazy"
						decoding="async"
					/>
					<div
						class="coach-yt-facade absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 lg:hidden"
					>
						<div class="absolute inset-0 bg-black/35" aria-hidden="true" />
						<button
							type="button"
							class="coach-yt-play relative z-10 inline-flex items-center gap-3 rounded-full bg-(--primary) px-5 py-3 text-base font-semibold text-(--on-primary) transition hover:bg-(--primary-container) focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--primary)"
						>
							<span aria-hidden="true">▶</span>
							Lancer la vidéo de présentation
						</button>
					</div>
					<iframe
						class="coach-yt-mobile pointer-events-none absolute inset-0 z-5 h-full w-full border-0 opacity-0 transition-opacity duration-200 lg:hidden"
						data-src={ytEmbedUrlAutoplay}
						title="Vidéo de présentation — Cécile, coach APA en ligne"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen"
						referrerpolicy="strict-origin-when-cross-origin"
						allowfullscreen
					/>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		(function () {
			var root = document.getElementById('coach-video-root');
			if (!root) return;
			if (window.matchMedia('(min-width: 1024px)').matches) return;

			var facade = root.querySelector('.coach-yt-facade');
			var poster = root.querySelector('.coach-yt-poster');
			var btn = root.querySelector('.coach-yt-play');
			var iframe = root.querySelector('.coach-yt-mobile');
			if (!btn || !iframe || !facade) return;

			btn.addEventListener('click', function () {
				var url = iframe.getAttribute('data-src');
				if (!url || iframe.getAttribute('src')) return;
				iframe.setAttribute('src', url);
				iframe.classList.remove('pointer-events-none', 'opacity-0');
				iframe.classList.add('opacity-100');
				facade.classList.add('hidden');
				if (poster) poster.classList.add('hidden');
			});
		})();
	</script>
</section>
