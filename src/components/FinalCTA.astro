---
import TunnelCtaLink from './TunnelCtaLink.astro';
import WhatsAppCtaLink from './WhatsAppCtaLink.astro';

const reveal =
	'opacity-0 translate-y-4 transition duration-700 ease-out will-change-transform will-change-opacity motion-reduce:transition-none data-[revealed=true]:opacity-100 data-[revealed=true]:translate-y-0';
---

<section
	id="cta"
	class={`relative overflow-hidden py-20 sm:px-10 ${reveal}`}
	data-reveal
	data-revealed="false"
	aria-labelledby="cta-title"
>
	<div
		class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-(--primary-fixed-dim)/20 blur-[100px]"
		aria-hidden="true"
	/>

	<div class="relative z-10 mx-auto max-w-(--max-width-container) px-4 sm:px-6 lg:px-8">
		<div class="rounded-[3rem] bg-(--primary) px-8 py-12 text-center text-(--on-primary) sm:px-16 sm:py-20 md:px-24">
			<h2 id="cta-title" class="text-3xl sm:text-5xl">
				Prête à reconnecter avec ton corps ?
			</h2>
			<p class="mx-auto mt-6 max-w-2xl text-lg text-(--on-primary-container)">
				Choisis une approche douce, progressive et à distance, réellement compatible avec ton quotidien de femme
				concernée par la maladie chronique, peu importe où tu es en France.
			</p>
			<div class="mt-10 flex flex-col justify-center gap-6 sm:flex-row sm:flex-wrap">
				<TunnelCtaLink
					campaign="final-cta"
					class="inline-flex items-center justify-center rounded-full bg-(--surface) px-10 py-5 text-lg font-bold text-(--primary) transition hover:bg-(--primary-fixed)"
				>
					Commencer l'immersion en ligne
				</TunnelCtaLink>
				<a
					href="#contact"
					class="inline-flex items-center justify-center rounded-full border border-(--on-primary)/30 px-10 py-5 text-lg font-bold text-(--on-primary) transition hover:bg-(--on-primary)/10"
				>
					Réserver un échange à distance
				</a>
				<WhatsAppCtaLink
					campaign="final-cta"
					showIcon={true}
					class="whatsapp-btn rounded-full px-10 py-5 text-lg font-bold"
				>
					Écrire sur WhatsApp
				</WhatsAppCtaLink>
			</div>
		</div>
	</div>
</section>
