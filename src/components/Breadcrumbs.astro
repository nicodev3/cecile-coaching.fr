---
/**
 * Fil d’Ariane visuel + JSON-LD BreadcrumbList (https://schema.org/BreadcrumbList)
 */
export interface Crumb {
	name: string;
	href: string;
}

interface Props {
	items: Crumb[];
	/** Style compact pour les articles de blog (Stitch) */
	variant?: 'default' | 'article';
}

const { items, variant = 'default' } = Astro.props;
const origin = Astro.site?.origin ?? Astro.url.origin;

const itemListElement = items.map((c, i) => ({
	'@type': 'ListItem',
	position: i + 1,
	name: c.name,
	item: new URL(c.href, origin).href,
}));

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement,
};
---

<nav
	aria-label="Fil d’Ariane"
	class:list={[
		'py-8',
		variant === 'article' ? 'text-xs text-(--outline)' : 'mb-8 text-sm text-(--on-surface-variant)',
	]}
>
	<ol class="flex flex-wrap items-center gap-2">
		{
			items.map((c, i) => (
				<li class="flex items-center gap-2">
					{i > 0 && <span aria-hidden="true" class="text-(--outline)">/</span>}
					{i === items.length - 1 ? (
						<span
							class:list={[
								variant === 'article'
									? 'text-(--on-surface-variant)'
									: 'font-medium text-(--on-surface)',
							]}
						>
							{c.name}
						</span>
					) : (
						<a
							href={c.href}
							class:list={[
								'transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)',
								variant === 'article'
									? 'text-(--outline) hover:text-(--primary) no-underline'
									: 'text-(--primary) underline-offset-2 hover:underline',
							]}
						>
							{c.name}
						</a>
					)}
				</li>
			))
		}
	</ol>
</nav>

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
