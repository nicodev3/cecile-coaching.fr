---
import { PILLAR_BY_KEY, type PillarKey } from '../data/pillars';

interface Props {
	relatedPillars?: PillarKey[];
}

const { relatedPillars = [] } = Astro.props;
---

{
	relatedPillars.length > 0 && (
		<aside
			class="not-prose mt-12 border-t border-(--outline-variant)/50 pt-10"
			aria-label="Sur le même thème"
		>
			<h2 class="mb-4 text-sm font-semibold tracking-widest text-(--primary) uppercase">
				Sur le même thème
			</h2>
			<ul class="flex flex-wrap gap-3 list-none p-0">
				{relatedPillars.map((key) => {
					const p = PILLAR_BY_KEY[key];
					return (
						<li>
							<a
								href={p.slug}
								class="inline-flex rounded-full border border-(--outline-variant) bg-(--surface-container-low) px-4 py-2 text-sm font-medium text-(--primary) no-underline transition hover:border-(--primary) hover:bg-(--primary-fixed) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)"
							>
								{p.shortLabel}
							</a>
						</li>
					);
				})}
			</ul>
		</aside>
	)
}
