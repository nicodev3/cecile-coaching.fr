---
import { PILLAR_BY_KEY, type PillarKey } from '../data/pillars';

interface Props {
	relatedPillars?: PillarKey[];
}

const { relatedPillars = [] } = Astro.props;
---

{
	relatedPillars.length > 0 && (
		<aside
			class="not-prose mt-12 border-t border-(--outline-variant)/50 pt-10"
			aria-label="Sur le même thème"
		>
			<h2 class="mb-4 text-sm font-semibold tracking-widest text-(--primary) uppercase">
				Sur le même thème
			</h2>
			<ul class="space-y-4 list-none p-0">
				{relatedPillars.map((key) => {
					const p = PILLAR_BY_KEY[key];
					return (
						<li class="rounded-2xl border border-(--outline-variant)/60 bg-(--surface-container-low) p-4">
							<a
								href={p.slug}
								class="block text-base font-semibold text-(--primary) no-underline transition hover:text-(--primary-container) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary)"
							>
								Guide : {p.label}
							</a>
							<p class="mt-1 text-sm leading-relaxed text-(--on-surface-variant)">{p.tagline}</p>
							<a
								href={p.archiveSlug}
								class="mt-3 inline-block text-sm font-medium text-(--primary) underline underline-offset-3 transition hover:text-(--primary-container)"
							>
								Tous les articles {p.shortLabel} →
							</a>
						</li>
					);
				})}
			</ul>
		</aside>
	)
}
